# =========================
# 前端环境变量示例
# 复制本文件为 .env.local 后再按实际环境修改
# =========================

# 前端本地开发端口
VITE_PORT=5173

# 后端 API 根地址
# 例如本地后端默认是 http://127.0.0.1:8000
VITE_API_BASE_URL=http://127.0.0.1:8000

# 后端统一 API 前缀
VITE_API_PREFIX=/api/v1

# 应用标题
VITE_APP_TITLE=协鑫集成经营计划部智能平台

# 是否开启调试日志
VITE_ENABLE_DEBUG=true
