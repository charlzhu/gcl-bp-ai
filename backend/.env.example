# =========================
# 应用基础配置
# =========================
APP_NAME=gcl-bp-ai
APP_ENV=local
APP_DEBUG=true
APP_VERSION=0.1.0
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

# =========================
# 跨域与请求头
# =========================
TRACE_HEADER_NAME=X-Trace-Id
REQUEST_ID_HEADER_NAME=X-Request-Id
ALLOWED_ORIGINS=["*"]

# =========================
# 文件与日志目录
# =========================
FILE_STORAGE_ROOT=data/files
LOG_ROOT=data/logs

# =========================
# 本地中间库 MySQL
# =========================
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DB=logistics_ai
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_CHARSET=utf8mb4

# =========================
# Redis
# =========================
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=

# =========================
# Milvus
# =========================
MILVUS_HOST=127.0.0.1
MILVUS_PORT=19530
MILVUS_USER=
MILVUS_PASSWORD=

# =========================
# 源系统 MySQL（只读）
# =========================
SOURCE_MYSQL_HOST=127.0.0.1
SOURCE_MYSQL_PORT=3306
SOURCE_MYSQL_DB=source_logistics
SOURCE_MYSQL_USER=readonly_user
SOURCE_MYSQL_PASSWORD=your_source_mysql_password

# =========================
# 大模型配置（后续预留）
# =========================
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=